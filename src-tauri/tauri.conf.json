{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Peek",
  "version": "1.1.1",
  "identifier": "io.github.peek.ha",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1431",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
